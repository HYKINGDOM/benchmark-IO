# ============================================
# 百万级数据导出跨语言性能基准测试系统 - Git Ignore
# ============================================

# ============================================
# OS Generated Files
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.tmp
*.swp
*~

# ============================================
# IDE / Editor
# ============================================
# IntelliJ / JetBrains
.idea/
*.iml
*.iws
*.ipr
out/

# VS Code
.vscode/
*.code-workspace
.history/

# Eclipse
.settings/
.project
.classpath

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.vim

# ============================================
# Java / Gradle
# ============================================
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*

# Application Local Config
application-local.yml
application-local.properties

# ============================================
# Golang
# ============================================
# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary
*.test

# Output of go coverage
*.out

# Go workspace
go.work
go.work.sum

# Vendor directory (if not committed)
vendor/

# ============================================
