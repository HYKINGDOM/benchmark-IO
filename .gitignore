# ============================================
.env
.env.local
.env.*.local
!.env.example

# ============================================
# Logs
# ============================================
logs/
*.log
log/

# ============================================
# Benchmark Results & Generated Files
# ============================================
# 保留目录结构但忽略生成的文件
benchmark/results/*.csv
benchmark/results/*.json
benchmark/results/*.txt
benchmark/results/**/*.csv
benchmark/results/**/*.json
benchmark/results/**/*.txt
!benchmark/results/.gitkeep
!benchmark/results/analysis/.gitkeep

benchmark/charts/*.png
benchmark/charts/*.svg
benchmark/charts/*.html
!benchmark/charts/.gitkeep

benchmark/reports/*.html
benchmark/reports/*.pdf
benchmark/reports/*.md
!benchmark/reports/.gitkeep

# ============================================
# Database
# ============================================
*.db
*.sqlite
*.sqlite3
*.sql.gz

# ============================================
# Temporary Export Files
# ============================================
*.csv
*.xlsx
*.xls
!init/

# ============================================
# Monitoring Data
