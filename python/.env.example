# Application
APP_NAME=Benchmark IO Python API
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/benchmark
DB_POOL_MIN=5
DB_POOL_MAX=20

# Redis
REDIS_URL=redis://localhost:6379/0

# API Keys (comma-separated)
API_KEYS=test-api-key-1,test-api-key-2

# API Key Roles (format: key1:role1,key2:role2)
API_KEY_ROLES_CONFIG=test-api-key-1:admin,test-api-key-2:user

# Export settings
EXPORT_DIR=/tmp/exports
EXPORT_FILE_EXPIRE_HOURS=24
EXPORT_MAX_RECORDS=1000000
