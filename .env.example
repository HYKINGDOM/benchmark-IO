# ==================== 数据库基础配置 ====================
POSTGRES_USER=benchmark
POSTGRES_PASSWORD=benchmark123
POSTGRES_DB=benchmark
POSTGRES_PORT=5432

# ==================== 应用服务数据库连接配置 ====================
# 以下变量用于各后端服务连接数据库（Docker 内部网络使用服务名）
DB_HOST=postgres
DB_PORT=5432
DB_USER=benchmark
DB_PASSWORD=benchmark123
DB_NAME=benchmark
DB_SSLMODE=disable

# ==================== API 认证配置 ====================
API_KEY=benchmark-api-key-2024

# ==================== 后端服务端口配置 ====================
JAVA_PORT=8080
GOLANG_PORT=8081
PYTHON_PORT=8082
RUST_PORT=8083

# ==================== 服务内部监听端口（容器内部） ====================
# Python Gunicorn 监听端口
PORT=8082
# Rust Axum 监听端口
SERVER_PORT=8083

# ==================== 前端配置 ====================
FRONTEND_PORT=80
VITE_JAVA_API_URL=http://localhost:8080
VITE_GOLANG_API_URL=http://localhost:8081
VITE_PYTHON_API_URL=http://localhost:8082
VITE_RUST_API_URL=http://localhost:8083

# ==================== 监控服务配置 ====================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123
CADVISOR_PORT=8084
POSTGRES_EXPORTER_PORT=9187

# Prometheus 配置
PROMETHEUS_RETENTION=30d
PROMETHEUS_RETENTION_SIZE=10GB

# ==================== 服务运行时配置 ====================
# Java JVM 配置
JAVA_OPTS=-Xms512m -Xmx1024m
GRADLE_OPTS=

# Python Gunicorn Workers
PYTHON_WORKERS=4
# Python API Keys（支持多 key，逗号分隔）
API_KEYS=benchmark-api-key-2024

# Rust 日志级别
RUST_LOG=info

# Golang Gin 模式
GIN_MODE=release

# ==================== 数据生成器配置 ====================
# 数据生成器批次大小
DATA_BATCH_SIZE=50000
# 数据生成器并发进程数
DATA_WORKERS=4
